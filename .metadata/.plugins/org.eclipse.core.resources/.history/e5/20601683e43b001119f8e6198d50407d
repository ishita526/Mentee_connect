package ui;

import javax.swing.*;
import java.awt.*;
import java.sql.*;
import db.DBConnection;

public class MentorDashboardUI {

    JFrame frame;
    int mentorId;

    JPanel centerPanel;

    public MentorDashboardUI(int mentorId) {

        this.mentorId = mentorId;

        frame = new JFrame("Mentor Dashboard");
        frame.setSize(600, 500);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        frame.setLayout(new BorderLayout());

        loadRequests();

        frame.setVisible(true);
    }

    private void loadRequests() {

        try {
            Connection con = DBConnection.getConnection();

            String query = "SELECT * FROM requests WHERE mentor_id=?";

            PreparedStatement ps = con.prepareStatement(query);
            ps.setInt(1, mentorId);

            ResultSet rs = ps.executeQuery();

            // ---------------- CENTER PANEL ----------------
            centerPanel = new JPanel();
            centerPanel.setLayout(new BoxLayout(centerPanel, BoxLayout.Y_AXIS));

            centerPanel.add(Box.createVerticalStrut(20));

            JLabel title = new JLabel("Incoming Requests");
            title.setAlignmentX(Component.CENTER_ALIGNMENT);
            title.setFont(new Font("Arial", Font.BOLD, 18));

            centerPanel.add(title);
            centerPanel.add(Box.createVerticalStrut(20));

            while (rs.next()) {

                int requestId = rs.getInt("request_id");
                int menteeId = rs.getInt("mentee_id");
                String status = rs.getString("status");

                JPanel row = new JPanel();
                row.setLayout(new FlowLayout(FlowLayout.CENTER, 20, 5));

                JLabel label = new JLabel(
                        "Mentee ID: " + menteeId + " | Status: " + status
                );

                JButton review = new JButton("REVIEW");

                review.addActionListener(e -> {
                    new ReviewRequestUI(requestId, menteeId, mentorId);
                    refresh();
                });

                row.add(label);
                row.add(review);

                centerPanel.add(row);
                centerPanel.add(Box.createVerticalStrut(10));
            }

            frame.add(centerPanel, BorderLayout.CENTER);

            frame.revalidate();
            frame.repaint();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void refresh() {
        frame.getContentPane().removeAll();
        frame.repaint();
        loadRequests();
        frame.revalidate();
    }
}