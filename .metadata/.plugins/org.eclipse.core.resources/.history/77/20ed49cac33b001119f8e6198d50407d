package ui;

import javax.swing.*;
import java.sql.*;
import dao.RequestDAO;
import db.DBConnection;

public class MenteeDashboardUI {

    JFrame frame;
    JTextField searchField;
    int menteeId;

    public MenteeDashboardUI(int menteeId) {

        this.menteeId = menteeId;

        frame = new JFrame("Mentee Dashboard");
        frame.setSize(600, 600);
        frame.setLayout(null);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        JLabel title = new JLabel("Available Mentors:");
        title.setBounds(50, 20, 200, 25);
        frame.add(title);

        // 🔍 SEARCH BOX
        searchField = new JTextField();
        searchField.setBounds(200, 20, 200, 25);
        frame.add(searchField);

        JButton searchBtn = new JButton("Search");
        searchBtn.setBounds(420, 20, 120, 25);
        frame.add(searchBtn);

        searchBtn.addActionListener(e -> refreshList(searchField.getText()));

        refreshList("");

        frame.setVisible(true);
    }

    // 🔥 LOAD / RELOAD DATA
    private void refreshList(String keyword) {

        try {
            Connection con = DBConnection.getConnection();

            String query;

            if (keyword == null || keyword.isEmpty()) {
                query = "SELECT * FROM mentors";
            } else {
                query = "SELECT * FROM mentors WHERE name LIKE ? OR skills LIKE ?";
            }

            PreparedStatement ps = con.prepareStatement(query);

            if (keyword != null && !keyword.isEmpty()) {
                ps.setString(1, "%" + keyword + "%");
                ps.setString(2, "%" + keyword + "%");
            }

            ResultSet rs = ps.executeQuery();

            int y = 70;

            while (rs.next()) {

                int mentorId = rs.getInt("mentor_id");
                String name = rs.getString("name");
                String skills = rs.getString("skills");
                int exp = rs.getInt("experience");

                JLabel label = new JLabel(
                        name + " | Skills: " + skills + " | Exp: " + exp + " yrs"
                );
                label.setBounds(50, y, 350, 25);

                JButton connect = new JButton("CONNECT");
                connect.setBounds(420, y, 120, 25);

                RequestDAO dao = new RequestDAO();

                connect.addActionListener(e -> {
                    dao.sendRequest(mentorId, menteeId);
                    JOptionPane.showMessageDialog(frame, "Request Sent!");
                });

                frame.add(label);
                frame.add(connect);

                y += 40;
            }

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}