package ui;

import javax.swing.*;
import service.SignupService;

public class MentorSignupUI {

    public MentorSignupUI() {

        JFrame frame = new JFrame("Mentor Signup");
        frame.setSize(450, 500);
        frame.setLayout(null);

        JTextField name = new JTextField();
        JTextField email = new JTextField();
        JTextField password = new JTextField();
        JTextField skills = new JTextField();
        JTextField experience = new JTextField();

        name.setBounds(180, 50, 180, 25);
        email.setBounds(180, 90, 180, 25);
        password.setBounds(180, 130, 180, 25);
        skills.setBounds(180, 170, 180, 25);
        experience.setBounds(180, 210, 180, 25);

        frame.add(new JLabel("Name:")).setBounds(50, 50, 100, 25);
        frame.add(name);
        frame.add(new JLabel("Email:")).setBounds(50, 90, 100, 25);
        frame.add(email);
        frame.add(new JLabel("Password:")).setBounds(50, 130, 100, 25);
        frame.add(password);
        frame.add(new JLabel("Skills:")).setBounds(50, 170, 100, 25);
        frame.add(skills);
        frame.add(new JLabel("Experience:")).setBounds(50, 210, 100, 25);
        frame.add(experience);

        JButton signup = new JButton("Signup");
        signup.setBounds(150, 300, 120, 30);
        frame.add(signup);

        signup.addActionListener(e -> {
            try {
                SignupService service = new SignupService();

                int exp = Integer.parseInt(experience.getText());

                service.registerMentor(
                        name.getText(),
                        email.getText(),
                        password.getText(),
                        skills.getText(),
                        exp
                );

                JOptionPane.showMessageDialog(frame, "Mentor Signup Successful!");

            } catch (Exception ex) {
                JOptionPane.showMessageDialog(frame, "Error: " + ex.getMessage());
            }
        });

        frame.setVisible(true);
    }
}