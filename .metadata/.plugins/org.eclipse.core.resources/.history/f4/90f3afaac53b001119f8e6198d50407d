package ui;

import javax.swing.*;
import dao.LoginDAO;
import util.Session;

public class MentorLoginUI {

    public MentorLoginUI() {

        JFrame frame = new JFrame("Mentor Login");
        frame.setSize(400, 300);
        frame.setLayout(null);

        JTextField email = new JTextField();
        JPasswordField password = new JPasswordField();

        email.setBounds(150, 80, 180, 25);
        password.setBounds(150, 120, 180, 25);

        frame.add(new JLabel("Email:")).setBounds(50, 80, 100, 25);
        frame.add(email);

        frame.add(new JLabel("Password:")).setBounds(50, 120, 100, 25);
        frame.add(password);

        JButton loginBtn = new JButton("Login");
        loginBtn.setBounds(150, 170, 120, 30);
        frame.add(loginBtn);

        loginBtn.addActionListener(e -> {

            try {
                LoginDAO dao = new LoginDAO();

                String pass = new String(password.getPassword());

                String[] data = dao.getMentorLogin(email.getText(), pass);

                if (data != null) {

                    int mentorId = Integer.parseInt(data[0]);
                    String name = data[1];

                    // session tracking
                    Session.userId = mentorId;
                    Session.role = "mentor";

                    JOptionPane.showMessageDialog(frame, "Login Success");

                    frame.dispose();

                    // pass BOTH id and name (important for dashboard UI)
                    new MentorDashboardUI(mentorId, name);

                } else {
                    JOptionPane.showMessageDialog(frame, "Invalid Credentials");
                }

            } catch (Exception ex) {
                ex.printStackTrace();
                JOptionPane.showMessageDialog(frame, "Error: " + ex.getMessage());
            }
        });

        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setVisible(true);
    }
}